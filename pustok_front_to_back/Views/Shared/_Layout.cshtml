@{
    ViewData["Title"] = "Pustok - Book Store";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <title>@ViewData["Title"]</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" type="text/css" media="screen" href="~/css/plugins.css" />
    <link rel="stylesheet" type="text/css" media="screen" href="~/css/main.css" />
    <link rel="shortcut icon" type="image/x-icon" href="~/image/favicon.ico">
</head>
<body>
    <div class="site-wrapper" id="top">
        <!-- Header Start -->
        <div class="site-header d-none d-lg-block">
            <div class="header-middle pt--10 pb--10">
                <div class="container">
                    <div class="row align-items-center">
                        <div class="col-lg-3">
                            <a href="/" class="site-brand">
                                <img src="/image/logo.png" alt="Pustok">
                            </a>
                        </div>
                        <div class="col-lg-3">
                            <div class="header-phone">
                                <div class="icon">
                                    <i class="fas fa-headphones-alt"></i>
                                </div>
                                <div class="text">
                                    <p>Free Support 24/7</p>
                                    <p class="font-weight-bold number">+01-202-555-0181</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-6">
                            <div class="main-navigation flex-lg-right">
                                <ul class="main-menu menu-right">
                                    <li class="menu-item has-children">
                                        <a href="javascript:void(0)">Shop <i class="fas fa-chevron-down dropdown-arrow"></i></a>
                                        <ul class="sub-menu">
                                            <li><a asp-controller="Home" asp-action="Shop">All Products</a></li>
                                            <li><a asp-controller="Home" asp-action="Shop">Featured</a></li>
                                        </ul>
                                    </li>
                                    <li class="menu-item">
                                        <a asp-controller="Home" asp-action="Index">Home</a>
                                    </li>
                                    <li class="menu-item">
                                        <a href="#">Contact</a>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="header-bottom pb--10">
                <div class="container">
                    <div class="row align-items-center">
                        <div class="col-lg-5">
                            <form asp-controller="Home" asp-action="Search" method="post" class="header-search-block">
                                <input type="text" name="query" placeholder="Search entire store here">
                                <button type="submit">Search</button>
                            </form>
                        </div>
                        <div class="col-lg-7">
                            <div class="main-navigation flex-lg-right">
                                <div class="cart-widget">
                                    <div class="login-block">
                                        @if (User.Identity.IsAuthenticated)
                                        {
                                            <span>Welcome, @User.Identity.Name</span> <br>
                                            <a href="/auth/logout" class="font-weight-bold">Logout</a>
                                        }
                                        else
                                        {
                                            <a asp-controller="Auth" asp-action="Login" class="font-weight-bold">Login</a> <br>
                                            <span>or</span> <a asp-controller="Auth" asp-action="Register">Register</a>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Header End -->

        <!-- Main Content -->
        <main role="main" class="pb--30 pt--30">
            @RenderBody()
        </main>

        <!-- Footer Start -->
        <footer class="footer-area section-padding bg-light-gray">
            <div class="container">
                <div class="row">
                    <div class="col-lg-4 col-md-6 mb--30">
                        <h4 class="footer-title">About Pustok</h4>
                        <p>Your ultimate online bookstore offering the best collection of books across all genres.</p>
                    </div>
                    <div class="col-lg-4 col-md-6 mb--30">
                        <h4 class="footer-title">Quick Links</h4>
                        <ul>
                            <li><a href="/">Home</a></li>
                            <li><a href="/home/shop">Shop</a></li>
                            <li><a href="#">About Us</a></li>
                            <li><a href="#">Contact</a></li>
                        </ul>
                    </div>
                    <div class="col-lg-4 col-md-6 mb--30">
                        <h4 class="footer-title">Contact Info</h4>
                        <p>Email: info@pustok.com</p>
                        <p>Phone: +01-202-555-0181</p>
                    </div>
                </div>
                <div class="row">
                    <div class="col-12 text-center">
                        <p>&copy; 2026 Pustok. All rights reserved.</p>
                    </div>
                </div>
            </div>
        </footer>
        <!-- Footer End -->
    </div>

    <script src="~/js/plugins.js"></script>
    <script src="~/js/custom.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>