@model Author
@{
    ViewData["Title"] = "Create Author";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <div class="row mb--30">
        <div class="col-12">
            <h1>Create New Author</h1>
            <hr />
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8 col-md-10">
            <form asp-controller="Admin" asp-action="CreateAuthor" method="post" enctype="multipart/form-data" class="card p--30">
                <div class="form-group mb--20">
                    <label asp-for="Name" class="form-label">Author Name</label>
                    <input asp-for="Name" class="form-control" placeholder="Enter author name" required>
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="form-group mb--20">
                    <label asp-for="Email" class="form-label">Email</label>
                    <input asp-for="Email" type="email" class="form-control" placeholder="Enter email address">
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="form-group mb--20">
                    <label asp-for="Bio" class="form-label">Biography</label>
                    <textarea asp-for="Bio" class="form-control" rows="4" placeholder="Enter author biography"></textarea>
                </div>

                <div class="form-group mb--20">
                    <label class="form-label">Profile Image</label>
                    <input type="file" name="profileImageFile" class="form-control" accept="image/*">
                    <small class="text-muted">Accepted formats: jpg, png, gif (Max 5MB)</small>
                </div>

                <div class="form-group">
                    <button type="submit" class="btn btn-success me--10">
                        <i class="fas fa-save"></i> Create Author
                    </button>
                    <a asp-controller="Admin" asp-action="Authors" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Back
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>