@model List<Product>
@{
    ViewData["Title"] = "Manage Products";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <div class="row mb--30">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <h1>Products Management</h1>
                <a asp-controller="Admin" asp-action="CreateProduct" class="btn btn-primary">
                    <i class="fas fa-plus"></i> Add New Product
                </a>
            </div>
            <hr />
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Image</th>
                        <th>Title</th>
                        <th>Author</th>
                        <th>Category</th>
                        <th>Price</th>
                        <th>Stock</th>
                        <th>On Sale</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var product in Model)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(product.Image))
                                {
                                    <img src="~/@product.Image" alt="@product.Title" style="width: 60px; height: 60px; object-fit: cover; border-radius: 4px;">
                                }
                            </td>
                            <td>@product.Title</td>
                            <td>@product.Author?.Name</td>
                            <td>@product.Category?.Name</td>
                            <td>£@product.Price.ToString("F2")</td>
                            <td>@product.Stock</td>
                            <td>
                                @if (product.IsOnSale)
                                {
                                    <span class="badge bg-success">On Sale</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Regular</span>
                                }
                            </td>
                            <td>
                                <a asp-controller="Admin" asp-action="EditProduct" asp-route-id="@product.Id" class="btn btn-sm btn-warning">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a asp-controller="Admin" asp-action="DeleteProduct" asp-route-id="@product.Id" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure?')">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center mt--20">
            <p>No products found. <a asp-controller="Admin" asp-action="CreateProduct">Create one now</a></p>
        </div>
    }
</div>