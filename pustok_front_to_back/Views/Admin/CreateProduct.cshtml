@model pustok_front_to_back.Controllers.CreateProductViewModel
@{
    ViewData["Title"] = "Create Product";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <div class="row mb--30">
        <div class="col-12">
            <h1>Create New Product</h1>
            <hr />
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8 col-md-10">
            <form asp-controller="Admin" asp-action="CreateProduct" method="post" enctype="multipart/form-data" class="card p--30">
                <div class="form-group mb--20">
                    <label class="form-label">Product Title</label>
                    <input name="Title" class="form-control" placeholder="Enter product title" required>
                </div>

                <div class="form-group mb--20">
                    <label class="form-label">Description</label>
                    <textarea name="Description" class="form-control" rows="4" placeholder="Enter product description"></textarea>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb--20">
                            <label class="form-label">Price</label>
                            <input name="Price" type="number" step="0.01" class="form-control" placeholder="0.00" required>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group mb--20">
                            <label class="form-label">Stock Quantity</label>
                            <input name="Stock" type="number" class="form-control" placeholder="0" value="0">
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb--20">
                            <label class="form-label">Author</label>
                            <select name="AuthorId" class="form-control" required>
                                <option value="">-- Select Author --</option>
                                @foreach (var author in Model.Authors)
                                {
                                    <option value="@author.Id">@author.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group mb--20">
                            <label class="form-label">Category</label>
                            <select name="CategoryId" class="form-control" required>
                                <option value="">-- Select Category --</option>
                                @foreach (var category in Model.Categories)
                                {
                                    <option value="@category.Id">@category.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>

                <div class="form-group mb--20">
                    <label class="form-label">SKU</label>
                    <input name="Sku" class="form-control" placeholder="Enter SKU">
                </div>

                <div class="form-group mb--20">
                    <label class="form-label">Product Image</label>
                    <input type="file" name="imageFile" class="form-control" accept="image/*" required>
                    <small class="text-muted">Accepted formats: jpg, png, gif (Max 5MB)</small>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-check mb--20">
                            <input name="IsOnSale" type="checkbox" class="form-check-input" id="isOnSale">
                            <label class="form-check-label" for="isOnSale">Is On Sale</label>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group mb--20">
                            <label class="form-label">Sale Price</label>
                            <input name="SalePrice" type="number" step="0.01" class="form-control" placeholder="0.00">
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <button type="submit" class="btn btn-success me--10">
                        <i class="fas fa-save"></i> Create Product
                    </button>
                    <a asp-controller="Admin" asp-action="Products" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Back
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>